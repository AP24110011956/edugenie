# Copy this file to .env and add your own credentials.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

# Use "gemini" for a lightweight setup. Set to "lamini" after installing
# requirements-lamini.txt to run MBZUAI/LaMini-Flan-T5-783M locally.
EXPLANATION_PROVIDER=gemini
LAMINI_MODEL=MBZUAI/LaMini-Flan-T5-783M

# Comma-separated browser origins allowed to call the API in production.
# Example: https://ap24110011956.github.io
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
